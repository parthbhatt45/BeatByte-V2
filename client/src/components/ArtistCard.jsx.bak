import { motion } from 'framer-motion';

function ArtistCard({ artist }) {
    const containerVariants = {
        hidden: { opacity: 0, y: 20 },
        visible: {
            opacity: 1,
            y: 0,
            transition: {
                duration: 0.5,
                ease: 'easeOut',
            },
        },
        hover: {
            y: -8,
            transition: {
                duration: 0.3,
                ease: 'easeOut',
            },
        },
    };

    const imageVariants = {
        hover: {
            scale: 1.05,
            transition: {
                duration: 0.3,
                ease: 'easeOut',
            },
        },
    };

    const textVariants = {
        hover: {
            color: '#ffffff',
            transition: {
                duration: 0.3,
            },
        },
    };

    return (
        <motion.div
            variants={containerVariants}
            initial="hidden"
            animate="visible"
            whileHover="hover"
            className="flex flex-col items-center justify-center p-6 rounded-3xl cursor-pointer group"
            style={{
                background: 'linear-gradient(145deg, #1a1a1a, #0f0f0f)',
                boxShadow:
                    '8px 8px 16px #0a0a0a, -8px -8px 16px #2a2a2a, inset 0px 1px 2px rgba(255, 255, 255, 0.1)',
            }}
        >
            <motion.div
                variants={imageVariants}
                whileHover="hover"
                className="relative mb-4"
            >
                <div
                    className="w-32 h-32 rounded-full overflow-hidden"
                    style={{
                        boxShadow:
                            'inset 0px 2px 8px rgba(0, 0, 0, 0.8), inset 0px -2px 8px rgba(255, 255, 255, 0.05)',
                    }}
                >
                    <img
                        src={artist.image}
                        alt={artist.name}
                        className="w-full h-full object-cover"
                    />
                </div>
                <div
                    className="absolute inset-0 rounded-full pointer-events-none"
                    style={{
                        boxShadow: 'inset 0px 0px 12px rgba(0, 0, 0, 0.6)',
                    }}
                />
            </motion.div>

            <motion.h3
                className="mt-4 font-semibold text-lg text-gray-100 text-center"
                variants={textVariants}
                whileHover="hover"
            >
                {artist.name}
            </motion.h3>

            <motion.p
                className="text-gray-500 text-sm mt-1 text-center group-hover:text-gray-300"
                initial={{ opacity: 0.7 }}
                whileHover={{ opacity: 1 }}
                transition={{ duration: 0.3 }}
            >
                Artist
            </motion.p>

            <motion.div
                className="mt-3 h-1 bg-gradient-to-r from-transparent via-purple-500 to-transparent rounded-full"
                initial={{ width: 0 }}
                whileHover={{ width: '60%' }}
                transition={{ duration: 0.3 }}
            />
        </motion.div>
    );
}

export default ArtistCard;
